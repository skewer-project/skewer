# Ignore Git
.git
.gitignore
.github

# Ignore CMake build artifacts and caches
build/
out/
install/
Testing/
CMakeUserPresets.json

# Ignore IDE configs
.vscode/
.idea/
.zed/
.cursor/

# Ignore outputs
objects/
scenes/
images/
*.exr
*.ppm

# Ignore Go binaries
coordinator
*.exe

# Ignore frontend dependencies
node_modules/
apps/scene-previewer/

# Ignore docs and scripts
docs/
scripts/

# Ignore Terraform state and provider cache (may contain sensitive values)
deployments/terraform/*.tfstate
deployments/terraform/*.tfstate.backup
deployments/terraform/.terraform/

# golden image tests
tests/integration