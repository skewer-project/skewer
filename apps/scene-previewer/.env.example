# Replace with your actual Cloud Run API URL.
# After `terraform apply`, copy the `api_url` value from the Terraform output.
VITE_API_URL=https://skewer-api-XXXXX.REGION.run.app

# Firebase web app credentials.
# Created in the Firebase Console when you register a web application.
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
